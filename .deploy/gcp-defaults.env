# AIMS-Core GCP Deployment Defaults
# This file is the project-local "Terraform-like" config.
# Override any value when the deploy skill prompts you.

# Source project (aims-core checkout)
AIMS_CORE_ROOT=/Users/kamir/GITHUB.active/my-ai-X/aims-core

# Default target environment: stage-new | stage-legacy | production
TARGET_ENV=stage-legacy

# Build platform (GCP Cloud Run)
BUILD_PLATFORMS=linux/arm64

# Deploy action: build-and-deploy | deploy-only | build-only
DEPLOY_ACTION=build-and-deploy

# Quick deploy: skip base image rebuild, only rebuild app layer (stages 4-5)
QUICK_DEPLOY=true
