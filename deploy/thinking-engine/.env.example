# .env.example — fill in and copy to ~/.m3c-engines/<ctx_hash>/.env
#
# SPEC-0167 §Deployment Topology §Phase 1: one stack per user, ports
# allocated per-user so multiple contexts can run side-by-side on
# the same host. CTX_HASH MUST match the hash the engine is started
# with; topic-bootstrap.sh enforces this.

# REQUIRED: hex prefix identifying this user's cluster.
# Compute with: echo -n "<your-user-context-id>" | shasum -a 256 | cut -c1-16
CTX_HASH=0123456789abcdef

# REQUIRED: raw user-context-id the engine binds to (never leaves this file).
M3C_USER_CONTEXT_ID=demo-user

# REQUIRED: HMAC secret used by Flask bridge + engine for bearer tokens.
THINKING_ENGINE_SECRET=change-me-please

# Per-user port allocation (PLAN-0167).
BROKER_PORT=9092
SCHEMA_REGISTRY_PORT=8081
CONTROL_CENTER_PORT=9021
ZOOKEEPER_PORT=2181
ENGINE_PORT=7140

# Engine image tag once we containerize it (Week 2+).
ENGINE_TAG=dev
