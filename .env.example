# ER1 Connection Settings
# Copy this file to .env and fill in your values.
# NEVER commit .env — it is listed in .gitignore.

# ER1 upload endpoint URL
# ER1_API_URL=https://127.0.0.1:8081/upload_2

# API key for ER1 authentication (sent as X-API-KEY header)
# ER1_API_KEY=

# Context identifier for ER1 uploads
# ER1_CONTEXT_ID=107677460544181387647___mft

# HTTP timeout (seconds) for ER1 upload requests
# ER1_UPLOAD_TIMEOUT=10

# Seconds between automatic retry-queue processing cycles
# ER1_RETRY_INTERVAL=300

# Maximum number of retry attempts before dropping a failed upload
# ER1_MAX_RETRIES=10

# Initial per-item backoff delay (seconds) for exponential retry backoff
# ER1_RETRY_BASE_DELAY=30

# Maximum per-item backoff delay (seconds) — caps exponential growth
# ER1_RETRY_MAX_DELAY=3600

# SSL verification: true | false (default: false for self-signed certs)
# ER1_VERIFY_SSL=false

# Content-type label in the ER1 upload form payload
# ER1_CONTENT_TYPE=YouTube-Video-Impression

# Whisper model size: tiny | base | small | medium | large
# YT_WHISPER_MODEL=large

# Comma-separated fallback chain if primary model fails to load
# YT_WHISPER_FALLBACK=medium,base,tiny

# Transcription timeout in seconds (0 = no timeout)
# YT_WHISPER_TIMEOUT=600

# Whisper transcription language (ISO 639-1 code)
# YT_WHISPER_LANGUAGE=en

# Root directory for MEMORY folders (impression storage)
# YT_MEMORY_DIR=~/Library/Application Support/YTTranscript/MEMORY

# --- Audio Import Settings ---

# Source folder for audio files (e.g. GDrive mirror)
# IMPORT_AUDIO_SOURCE=/Users/kamir/GDMirror/GCP-AUDIO-TRANSCRIPT-SERVICE

# Destination base folder for imported MEMORY folders
# IMPORT_AUDIO_DEST=~/ER1

# Content-type label for audio imports (ER1 form field)
# IMPORT_CONTENT_TYPE=Audio-Track vom Diktiergerät

# Path to transcript tracker file (tracks which files have been imported)
# IMPORT_TRACKER_FILE=~/.m3c-tools/transcript_tracker.md
