# ER1 Connection Settings
# Copy this file to .env and fill in your values.
# NEVER commit .env — it is listed in .gitignore.

# ER1 upload endpoint URL
# Local ER1 instance (for development):
# ER1_API_URL=https://127.0.0.1:8081/upload_2
# Public ER1 instance (for testing without a local server):
# ER1_API_URL=https://onboarding.guide/upload_2

# API key for ER1 authentication (sent as X-API-KEY header)
# ER1_API_KEY=

# Context identifier for ER1 uploads
# ER1_CONTEXT_ID=107677460544181387647___mft

# HTTP timeout (seconds) for ER1 upload requests
# ER1_UPLOAD_TIMEOUT=600

# Seconds between automatic retry-queue processing cycles
# ER1_RETRY_INTERVAL=300

# Maximum number of retry attempts before dropping a failed upload
# ER1_MAX_RETRIES=10

# Initial per-item backoff delay (seconds) for exponential retry backoff
# ER1_RETRY_BASE_DELAY=30

# Maximum per-item backoff delay (seconds) — caps exponential growth
# ER1_RETRY_MAX_DELAY=3600

# SSL verification: true | false
# Set false for local dev with self-signed certs. The public instance
# (onboarding.guide) uses a valid Let's Encrypt certificate, so true works there.
# ER1_VERIFY_SSL=false

# Content-type label in the ER1 upload form payload
# ER1_CONTENT_TYPE=YouTube-Video-Impression

# Persist ER1 login-linked context across app restarts (menubar login/logout flow).
# Default is false (runtime-only session).
# M3C_ER1_SESSION_PERSIST=false

# Optional custom path for persisted ER1 session JSON.
# M3C_ER1_SESSION_FILE=~/.m3c-tools/er1_session.json

# --- YouTube Rate Limit Mitigation ---

# HTTP/SOCKS5 proxy to avoid YouTube 429 rate limits.
# Transcripts are also cached locally at ~/.m3c-tools/cache/transcripts/ (7-day TTL).
# On 429, the app proceeds without transcript (graceful degradation).
# YT_PROXY_URL=socks5://host:port
# YT_PROXY_AUTH=user:password

# --- Whisper Transcription Settings ---
# Used for: menubar voice recording, audio import, local speech-to-text.
# NOT used for YouTube transcripts (those are fetched directly as text).

# Whisper model size: tiny | base | small | medium | large
# M3C_WHISPER_MODEL=large

# Comma-separated fallback chain if primary model fails to load
# M3C_WHISPER_FALLBACK=medium,base,tiny

# Transcription timeout in seconds (0 = no timeout)
# M3C_WHISPER_TIMEOUT=7200

# Whisper transcription language (ISO 639-1 code)
# M3C_WHISPER_LANGUAGE=de

# Preload whisper model at menubar app startup (reduces first transcription latency).
# M3C_WHISPER_PRELOAD=true

# Screenshot capture mode:
#   clipboard-first      recommended for menu bar apps (default)
#   interactive          runs screencapture -s (legacy, focus-sensitive)
#   screencapture-legacy alias for interactive
# M3C_SCREENSHOT_MODE=clipboard-first

# Timeout (seconds) to wait for clipboard screenshot in clipboard-first mode.
# M3C_SCREENSHOT_CLIPBOARD_TIMEOUT_SEC=20

# Delay (ms) before interactive screenshot starts from menu bar actions.
# Helps macOS restore the previously active app/window after LSUIElement focus shift.
# Start at 700 ms. Tune in 100 ms steps (common range: 500-1200 ms).
# Set 0 to disable waiting.
# Note: interactive capture also requires Screen Recording permission for m3c-tools.
# M3C_SCREENSHOT_FOCUS_DELAY_MS=700

# Root directory for MEMORY folders (impression storage)
# YT_MEMORY_DIR=~/Library/Application Support/YTTranscript/MEMORY

# --- Audio Import Settings ---

# Source folder for audio files (e.g. GDrive mirror)
# IMPORT_AUDIO_SOURCE=/Users/kamir/GDMirror/GCP-AUDIO-TRANSCRIPT-SERVICE

# Destination base folder for imported MEMORY folders
# IMPORT_AUDIO_DEST=~/ER1

# Content-type label for audio imports (ER1 form field)
# IMPORT_CONTENT_TYPE=Audio-Track vom Diktiergerät

# Path to transcript tracker file (tracks which files have been imported)
# IMPORT_TRACKER_FILE=~/.m3c-tools/transcript_tracker.md

# --- Plaud.ai Integration ---

# Plaud API base URL
# PLAUD_API_URL=https://api.plaud.ai

# Path to Plaud session token file
# PLAUD_TOKEN_FILE=~/.m3c-tools/plaud-session.json

# Content-type label for Plaud fieldnote uploads (ER1 form field)
# PLAUD_CONTENT_TYPE=Plaud-Fieldnote
